# Application
DEBUG=true
VERSION=0.0.1

# Database
DATABASE_URL=postgresql+asyncpg://agromind:agromind@localhost:5432/agromind
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20

# TimescaleDB (Telemetry)
TIMESCALE_URL=postgresql://agromind:agromind@localhost:5433/telemetry

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_COMPRESSION_TYPE=snappy

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Vision
VISION_MODEL_PATH=/models/yolov11m.onnx
VISION_CONFIDENCE_THRESHOLD=0.5
VISION_IOU_THRESHOLD=0.45

# Robotics
ROBOTICS_ENABLE_SIMULATION=true
ROBOTICS_BASE_URL=http://localhost:9000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# AWS/GCP (for cloud deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GCP_PROJECT_ID=
GCP_CREDENTIALS=

# Monitoring
PROMETHEUS_RETENTION=30d
GRAFANA_ADMIN_PASSWORD=admin
